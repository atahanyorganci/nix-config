{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"plugins": [
			{
				"name": "@effect/language-service",
				"diagnosticSeverity": {
					"deterministicKeys": "error"
				}
			}
		]
	},
	"include": [
		"./oxfmt.config.ts",
		"./oxlint.config.ts",
		"./src/**/*.ts",
		"./src/**/*.tsx",
		"./test/**/*.ts",
		"./test/**/*.tsx"
	]
}
