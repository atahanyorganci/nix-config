{
  flake.modules.nixos.netbird-server = {
    lib,
    config,
    pkgs,
    ...
  }: let
    cfg = config.netbird-server;

    stateDir = "/var/lib/netbird";
    secretsDir = "${stateDir}/secrets";
    runtimeDir = "/run/netbird-server";
    listenPort = 8081;
    healthcheckPort = 9000;
    metricsPort = 9090;
    stunPort = 3478;

    # Placeholders are replaced at service start so secrets stay out of the Nix store.
    configTemplate = pkgs.writeText "netbird-server-config.yaml" ''
      # Generated by NixOS netbird-server module. Secrets are injected at runtime.
      server:
        listenAddress: "127.0.0.1:${toString listenPort}"
        exposedAddress: "https://${cfg.domain}:443"
        stunPorts:
          - ${toString stunPort}
        metricsPort: ${toString metricsPort}
        healthcheckAddress: "127.0.0.1:${toString healthcheckPort}"
        logLevel: "info"
        logFile: "console"
        authSecret: "@authSecret@"
        dataDir: "${stateDir}"
        disableAnonymousMetrics: true
        disableGeoliteUpdate: false
        auth:
          issuer: "https://${cfg.domain}/oauth2"
          localAuthDisabled: false
          signKeyRefreshEnabled: true
          sessionCookieEncryptionKey: "@sessionCookieKey@"
          dashboardRedirectURIs:
            - "https://${cfg.domain}/nb-auth"
            - "https://${cfg.domain}/nb-silent-auth"
          cliRedirectURIs:
            - "http://localhost:53000/"
        store:
          engine: "sqlite"
          encryptionKey: "@encryptionKey@"
        reverseProxy:
          trustedHTTPProxies:
            - "127.0.0.1/32"
            - "::1/128"
    '';

    dashboardDrv = let
      settings = {
        AUTH_AUDIENCE = "netbird-dashboard";
        AUTH_CLIENT_ID = "netbird-dashboard";
        AUTH_CLIENT_SECRET = "";
        AUTH_AUTHORITY = "https://${cfg.domain}/oauth2";
        AUTH_SUPPORTED_SCOPES = "openid profile email groups";
        AUTH_REDIRECT_URI = "/nb-auth";
        AUTH_SILENT_REDIRECT_URI = "/nb-silent-auth";
        NETBIRD_TOKEN_SOURCE = "accessToken";
        USE_AUTH0 = false;
        NETBIRD_MGMT_API_ENDPOINT = "https://${cfg.domain}";
        NETBIRD_MGMT_GRPC_API_ENDPOINT = "https://${cfg.domain}";
      };
      toStringEnv = value:
        if builtins.isBool value
        then lib.boolToString value
        else toString value;
    in
      pkgs.runCommand "netbird-dashboard-templated" {
        nativeBuildInputs = [pkgs.gettext];
        env =
          {
            ENV_STR = lib.concatStringsSep " " [
              "$AUTH_AUDIENCE"
              "$AUTH_AUTHORITY"
              "$AUTH_CLIENT_ID"
              "$AUTH_CLIENT_SECRET"
              "$AUTH_REDIRECT_URI"
              "$AUTH_SILENT_REDIRECT_URI"
              "$AUTH_SUPPORTED_SCOPES"
              "$NETBIRD_DRAG_QUERY_PARAMS"
              "$NETBIRD_GOOGLE_ANALYTICS_ID"
              "$NETBIRD_GOOGLE_TAG_MANAGER_ID"
              "$NETBIRD_HOTJAR_TRACK_ID"
              "$NETBIRD_MGMT_API_ENDPOINT"
              "$NETBIRD_MGMT_GRPC_API_ENDPOINT"
              "$NETBIRD_TOKEN_SOURCE"
              "$NETBIRD_WASM_PATH"
              "$USE_AUTH0"
            ];
          }
          // (lib.mapAttrs (_: toStringEnv) settings);
      } ''
        cp -R ${pkgs.netbird-dashboard} build
        find build -type d -exec chmod 755 {} \;
        OIDC_TRUSTED_DOMAINS="build/OidcTrustedDomains.js"
        envsubst "$ENV_STR" < "$OIDC_TRUSTED_DOMAINS.tmpl" > "$OIDC_TRUSTED_DOMAINS"
        for f in $(grep -R -l AUTH_SUPPORTED_SCOPES build/); do
          mv "$f" "$f.copy"
          envsubst "$ENV_STR" < "$f.copy" > "$f"
          rm "$f.copy"
        done
        cp -R build $out
      '';

    prepareConfig = pkgs.writeShellApplication {
      name = "netbird-server-prepare-config";
      runtimeInputs = [pkgs.openssl pkgs.replace-secret];
      text = ''
        set -euo pipefail

        mkdir -p ${lib.escapeShellArg secretsDir}
        chmod 700 ${lib.escapeShellArg secretsDir}

        auth_secret=${lib.escapeShellArg "${secretsDir}/auth-secret"}
        encryption_key=${lib.escapeShellArg "${secretsDir}/store-encryption-key"}
        session_cookie_key=${lib.escapeShellArg "${secretsDir}/session-cookie-key"}
        runtime_config=${lib.escapeShellArg "${runtimeDir}/config.yaml"}

        if [[ ! -s "$auth_secret" ]]; then
          openssl rand -base64 32 | tr -d '=\n' >"$auth_secret"
          chmod 600 "$auth_secret"
        fi

        if [[ ! -s "$encryption_key" ]]; then
          # Keep base64 padding; NetBird decodes this as a 32-byte AES key.
          openssl rand -base64 32 | tr -d '\n' >"$encryption_key"
          chmod 600 "$encryption_key"
        fi

        if [[ ! -s "$session_cookie_key" ]]; then
          openssl rand -hex 16 | tr -d '\n' >"$session_cookie_key"
          chmod 600 "$session_cookie_key"
        fi

        install -m 600 ${configTemplate} "$runtime_config"

        replace-secret '@authSecret@' "$auth_secret" "$runtime_config"
        replace-secret '@encryptionKey@' "$encryption_key" "$runtime_config"
        replace-secret '@sessionCookieKey@' "$session_cookie_key" "$runtime_config"
      '';
    };
  in {
    options.netbird-server = {
      enable = lib.mkEnableOption "self-hosted NetBird unified server";

      domain = lib.mkOption {
        type = lib.types.str;
        example = "netbird.example.com";
        description = "Public hostname for the NetBird dashboard, API, signal, and relay.";
      };

      acmeEmail = lib.mkOption {
        type = lib.types.str;
        description = "Email address used for Let's Encrypt ACME registration.";
      };

      package = lib.mkOption {
        type = lib.types.package;
        default = pkgs.netbird-server;
        defaultText = lib.literalExpression "pkgs.netbird-server";
        description = "Combined NetBird server package.";
      };
    };

    config = lib.mkIf cfg.enable {
      users.users.netbird = {
        isSystemUser = true;
        group = "netbird";
        home = stateDir;
        createHome = true;
      };
      users.groups.netbird = {};

      networking.firewall = {
        allowedTCPPorts = [80 443];
        allowedUDPPorts = [stunPort];
      };

      security.acme = {
        acceptTerms = true;
        defaults.email = cfg.acmeEmail;
      };

      services.nginx = {
        enable = true;
        recommendedProxySettings = true;
        recommendedTlsSettings = true;
        virtualHosts.${cfg.domain} = {
          forceSSL = true;
          enableACME = true;
          root = dashboardDrv;
          extraConfig = ''
            # Long-lived gRPC / WebSocket sessions.
            client_header_timeout 1d;
            client_body_timeout 1d;
          '';
          locations = {
            "/".tryFiles = "$uri $uri.html $uri/ /index.html";

            # WebSocket: relay + management/signal ws-proxy
            "~ ^/(relay|ws-proxy/)".extraConfig = ''
              proxy_pass http://127.0.0.1:${toString listenPort};
              proxy_http_version 1.1;
              proxy_set_header Upgrade $http_upgrade;
              proxy_set_header Connection "upgrade";
              proxy_set_header Host $host;
              proxy_set_header X-Real-IP $remote_addr;
              proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
              proxy_set_header X-Forwarded-Proto $scheme;
              proxy_read_timeout 1d;
            '';

            # Native gRPC (HTTP/2)
            "~ ^/(signalexchange\\.SignalExchange|management\\.ManagementService)/".extraConfig = ''
              grpc_pass grpc://127.0.0.1:${toString listenPort};
              grpc_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
              grpc_read_timeout 1d;
              grpc_send_timeout 1d;
              grpc_socket_keepalive on;
            '';

            # Management HTTP API + embedded Dex (OIDC)
            "~ ^/(api|oauth2)".extraConfig = ''
              proxy_pass http://127.0.0.1:${toString listenPort};
              proxy_set_header Host $host;
              proxy_set_header X-Real-IP $remote_addr;
              proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
              proxy_set_header X-Forwarded-Proto $scheme;
              proxy_set_header X-Forwarded-Host $host;
            '';
          };
        };
      };

      systemd.services.netbird-server = {
        description = "NetBird combined management/signal/relay/STUN server";
        documentation = ["https://docs.netbird.io/selfhosted/selfhosted-quickstart"];
        after = ["network-online.target" "nginx.service"];
        wants = ["network-online.target"];
        wantedBy = ["multi-user.target"];

        serviceConfig = {
          Type = "simple";
          User = "netbird";
          Group = "netbird";
          ExecStartPre = ["${lib.getExe prepareConfig}"];
          ExecStart = "${lib.getExe cfg.package} --config ${runtimeDir}/config.yaml";
          Restart = "on-failure";
          RestartSec = "5s";

          StateDirectory = "netbird";
          StateDirectoryMode = "0750";
          RuntimeDirectory = "netbird-server";
          RuntimeDirectoryMode = "0750";
          WorkingDirectory = stateDir;

          # Hardening
          NoNewPrivileges = true;
          PrivateTmp = true;
          ProtectSystem = "strict";
          ProtectHome = true;
          ProtectKernelTunables = true;
          ProtectKernelModules = true;
          ProtectControlGroups = true;
          ProtectHostname = true;
          ProtectClock = true;
          LockPersonality = true;
          MemoryDenyWriteExecute = true;
          RestrictSUIDSGID = true;
          RestrictRealtime = true;
          RestrictNamespaces = true;
          RemoveIPC = true;
          SystemCallArchitectures = "native";
          ReadWritePaths = [stateDir runtimeDir];
          CapabilityBoundingSet = "";
          AmbientCapabilities = "";
        };
      };
    };
  };
}
